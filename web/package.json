{
  "name": "@ppoker/web-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "wasm:generate": "pnpm --filter @ppoker/web-client run wasm:generate",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "pnpm --filter @ppoker/web-client run typecheck",
    "declarations": "pnpm --filter @ppoker/web-client run declarations",
    "test": "pnpm --filter @ppoker/web-client run test",
    "coverage": "pnpm --filter @ppoker/web-client run coverage",
    "test:wasm": "pnpm --filter @ppoker/web-client run test:wasm",
    "test:wasm:live": "pnpm --filter @ppoker/web-client run test:wasm:live",
    "build": "pnpm --filter @ppoker/web-client run build",
    "package:verify": "pnpm --filter @ppoker/web-client run package:verify",
    "check": "pnpm --filter @ppoker/web-client run check"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0"
  }
}
